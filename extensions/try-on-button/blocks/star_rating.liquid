<div class="feyre-tryon-wrap">
  <button
    type="button"
    class="feyre-tryon-btn"
    onclick="feyreOpenTryOn()">
    Try On
  </button>
</div>

<div id="feyre-tryon-modal" class="feyre-tryon-modal" style="display:none;">
  <div class="feyre-tryon-shell">

    <button
      type="button"
      class="feyre-tryon-close"
      onclick="feyreCloseTryOn()">
      ×
    </button>

    <!-- STEP 1: UPLOAD -->
    <div id="feyre-step-upload" class="feyre-step">
      <div class="feyre-step-head">
        <h2>Virtual Try On</h2>
        <p>Upload your photo to preview this outfit.</p>
      </div>

      <div class="feyre-tryon-grid">
        {% if product.featured_image %}
          <div class="feyre-card">
            <div class="feyre-card-label">Outfit preview</div>
            <img
              class="feyre-preview-img"
              src="{{ product.featured_image | image_url: width: 700 }}"
              alt="{{ product.title | escape }}"
              width="320"
              height="420">
          </div>
        {% endif %}

        <div class="feyre-card">
          <div class="feyre-card-label">Your photo</div>

          <label class="feyre-upload-box" for="feyre-tryon-upload">
            <span class="feyre-upload-title">Choose your image</span>
            <span class="feyre-upload-subtitle">Front-facing photo works best</span>
          </label>

          <input
            type="file"
            id="feyre-tryon-upload"
            accept="image/*"
            onchange="feyrePreviewImage(event)">

          <div id="feyre-file-name" class="feyre-file-name" style="display:none;"></div>

          <div id="feyre-tryon-preview-wrap" style="display:none;">
            <img
              id="feyre-tryon-preview"
              class="feyre-preview-img"
              src=""
              alt="Preview"
              width="320"
              height="420">
          </div>
        </div>
      </div>

      <div class="feyre-actions">
        <button
          type="button"
          class="feyre-btn feyre-btn-secondary"
          onclick="feyreCloseTryOn()">
          Cancel
        </button>

        <button
          type="button"
          id="feyre-generate-btn"
          class="feyre-btn feyre-btn-primary"
          onclick="feyreGenerateTryOn()">
          Generate Try On
        </button>
      </div>
    </div>

    <!-- STEP 2: LOADING -->
    <div id="feyre-step-loading" class="feyre-step" style="display:none;">
      <div class="feyre-loading-wrap">
        <h2>Generating your fit</h2>

        <div class="feyre-loading-card">
          <div class="feyre-scan-line"></div>
          <img
            id="feyre-loading-preview"
            src=""
            alt="Loading preview">
        </div>

        <div class="feyre-progress-wrap">
          <div class="feyre-progress-bar">
            <div id="feyre-progress-fill" class="feyre-progress-fill"></div>
          </div>
          <div id="feyre-progress-text" class="feyre-progress-text">12% Complete</div>
          <div id="feyre-loading-status" class="feyre-loading-status">Analyzing your photo...</div>
        </div>

        <div class="feyre-loading-note">
          Lighting is matched to your photo for true fabric colors.
        </div>

        <div class="feyre-powered">
          Powered by <span>FEYRE Try On</span>
        </div>
      </div>
    </div>

    <!-- STEP 3: RESULT -->
    <div id="feyre-step-result" class="feyre-step" style="display:none;">
      <div class="feyre-step-head feyre-result-head">
        <h2>Your try-on preview</h2>
        <p>Here is your generated look.</p>
      </div>

      <div class="feyre-result-image-wrap">
        <img
          id="feyre-result-image"
          class="feyre-result-image"
          src=""
          alt="Generated try-on result"
          width="420"
          height="560">
      </div>

      <div class="feyre-actions feyre-result-actions">
        <button
          type="button"
          class="feyre-btn feyre-btn-secondary"
          onclick="feyreBackToUpload()">
          Try another photo
        </button>

        <button
          type="button"
          class="feyre-btn feyre-btn-primary"
          onclick="feyreCloseTryOn()">
          Done
        </button>
      </div>
    </div>

    <!-- ERROR -->
    <div id="feyre-error-box" class="feyre-error-box" style="display:none;">
      <div class="feyre-error-title">Something went wrong</div>
      <pre id="feyre-error-text"></pre>
    </div>

  </div>
</div>

<style>
  .feyre-tryon-btn {
    padding: 13px 24px;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: all .2s ease;
  }

  .feyre-tryon-btn:hover {
    opacity: .92;
    transform: translateY(-1px);
  }

  .feyre-tryon-modal {
    position: fixed;
    inset: 0;
    background: rgba(15, 18, 26, 0.58);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 99999;
    padding: 24px;
    backdrop-filter: blur(4px);
  }

  .feyre-tryon-shell {
    position: relative;
    width: 100%;
    max-width: 1080px;
    max-height: 92vh;
    overflow-y: auto;
    background: #f6f6f7;
    border-radius: 26px;
    padding: 34px;
    box-shadow: 0 25px 70px rgba(0,0,0,.18);
  }

  .feyre-tryon-close {
    position: absolute;
    top: 18px;
    right: 20px;
    border: none;
    background: transparent;
    font-size: 34px;
    line-height: 1;
    cursor: pointer;
    color: #8b8f98;
  }

  .feyre-step-head {
    text-align: left;
    margin-bottom: 24px;
  }

  .feyre-step-head h2 {
    margin: 0 0 8px;
    font-size: 28px;
    font-weight: 700;
    color: #1f2937;
  }

  .feyre-step-head p {
    margin: 0;
    font-size: 16px;
    color: #6b7280;
  }

  .feyre-tryon-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  .feyre-card {
    background: #fff;
    border: 1px solid #e7e8ec;
    border-radius: 22px;
    padding: 20px;
    box-shadow: 0 8px 24px rgba(16,24,40,.04);
  }

  .feyre-card-label {
    font-size: 15px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 14px;
  }

  .feyre-preview-img,
  .feyre-result-image {
    width: 100%;
    height: 420px;
    object-fit: contain;
    background: #fafafa;
    border-radius: 18px;
    display: block;
  }

  .feyre-upload-box {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 130px;
    border: 2px dashed #d5d9e2;
    border-radius: 18px;
    background: #fbfbfc;
    text-align: center;
    padding: 18px;
    cursor: pointer;
    margin-bottom: 14px;
  }

  .feyre-upload-title {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
  }

  .feyre-upload-subtitle {
    margin-top: 6px;
    font-size: 13px;
    color: #6b7280;
  }

  #feyre-tryon-upload {
    display: none;
  }

  .feyre-file-name {
    font-size: 14px;
    color: #4b5563;
    margin-bottom: 14px;
    word-break: break-word;
  }

  .feyre-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 24px;
  }

  .feyre-btn {
    min-width: 150px;
    padding: 14px 22px;
    border-radius: 14px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: all .2s ease;
  }

  .feyre-btn:disabled {
    opacity: .65;
    cursor: not-allowed;
  }

  .feyre-btn-primary {
    background: #111827;
    color: #fff;
    border: none;
  }

  .feyre-btn-secondary {
    background: #fff;
    color: #111827;
    border: 1px solid #d6d8de;
  }

  .feyre-loading-wrap {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    padding: 8px 0 10px;
  }

  .feyre-loading-wrap h2 {
    margin: 0 0 26px;
    font-size: 34px;
    font-weight: 800;
    color: #1f2937;
  }

  .feyre-loading-card {
    position: relative;
    width: 100%;
    max-width: 420px;
    margin: 0 auto 28px;
    border-radius: 26px;
    overflow: hidden;
    background: #111;
    padding: 0;
    box-shadow: 0 14px 38px rgba(17,24,39,.18);
  }

  .feyre-loading-card img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    display: block;
  }

  .feyre-scan-line {
    position: absolute;
    left: 0;
    right: 0;
    top: 18%;
    height: 3px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.95), transparent);
    box-shadow: 0 0 20px rgba(255,255,255,.8);
    animation: feyreScan 2.2s linear infinite;
    z-index: 2;
  }

  @keyframes feyreScan {
    0% { top: 10%; }
    50% { top: 82%; }
    100% { top: 10%; }
  }

  .feyre-progress-wrap {
    max-width: 600px;
    margin: 0 auto 22px;
  }

  .feyre-progress-bar {
    height: 12px;
    background: #d9dde5;
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 14px;
  }

  .feyre-progress-fill {
    height: 100%;
    width: 12%;
    background: #111;
    border-radius: 999px;
    transition: width .4s ease;
  }

  .feyre-progress-text {
    font-size: 18px;
    font-weight: 600;
    color: #9aa1ad;
    margin-bottom: 6px;
  }

  .feyre-loading-status {
    font-size: 18px;
    font-weight: 700;
    color: #334155;
  }

  .feyre-loading-note {
    max-width: 620px;
    margin: 28px auto 0;
    padding: 18px 20px;
    border: 1px solid #e4e7ee;
    border-radius: 20px;
    background: #fbfbfc;
    color: #7b8494;
    font-size: 15px;
    line-height: 1.5;
  }

  .feyre-powered {
    margin-top: 30px;
    color: #b0b6c2;
    font-size: 16px;
  }

  .feyre-powered span {
    color: #6d5dd3;
    font-weight: 700;
  }

  .feyre-result-head {
    text-align: center;
  }

  .feyre-result-image-wrap {
    max-width: 460px;
    margin: 0 auto;
    background: #fff;
    border: 1px solid #e7e8ec;
    border-radius: 24px;
    padding: 18px;
    box-shadow: 0 8px 24px rgba(16,24,40,.04);
  }

  .feyre-result-image {
    height: 560px;
    border-radius: 18px;
  }

  .feyre-result-actions {
    justify-content: center;
  }

  .feyre-error-box {
    margin-top: 20px;
    padding: 18px;
    border-radius: 18px;
    background: #fff1f2;
    border: 1px solid #fecdd3;
  }

  .feyre-error-title {
    font-size: 16px;
    font-weight: 700;
    color: #9f1239;
    margin-bottom: 10px;
  }

  .feyre-error-box pre {
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 13px;
    color: #881337;
  }

  @media (max-width: 768px) {
    .feyre-tryon-shell {
      padding: 24px 16px;
      border-radius: 20px;
    }

    .feyre-tryon-grid {
      grid-template-columns: 1fr;
    }

    .feyre-preview-img {
      height: 320px;
    }

    .feyre-loading-card img,
    .feyre-result-image {
      height: 420px;
    }

    .feyre-actions,
    .feyre-result-actions {
      flex-direction: column;
    }

    .feyre-btn {
      width: 100%;
    }

    .feyre-loading-wrap h2 {
      font-size: 28px;
    }
  }
</style>

<script>
  let feyreProgressInterval = null;

  function feyreOpenTryOn() {
    document.getElementById('feyre-tryon-modal').style.display = 'flex';
    feyreShowStep('upload');
    feyreHideError();
  }

  function feyreCloseTryOn() {
    document.getElementById('feyre-tryon-modal').style.display = 'none';
    feyreStopFakeProgress();
  }

  function feyreBackToUpload() {
    feyreShowStep('upload');
    feyreHideError();
  }

  function feyreShowStep(step) {
    document.getElementById('feyre-step-upload').style.display = step === 'upload' ? 'block' : 'none';
    document.getElementById('feyre-step-loading').style.display = step === 'loading' ? 'block' : 'none';
    document.getElementById('feyre-step-result').style.display = step === 'result' ? 'block' : 'none';
  }

  function feyreHideError() {
    document.getElementById('feyre-error-box').style.display = 'none';
    document.getElementById('feyre-error-text').textContent = '';
  }

  function feyreShowError(message) {
    document.getElementById('feyre-error-box').style.display = 'block';
    document.getElementById('feyre-error-text').textContent = message || 'Unknown error';
  }

  function feyrePreviewImage(event) {
    var file = event.target.files && event.target.files[0];
    if (!file) return;

    var fileName = document.getElementById('feyre-file-name');
    fileName.textContent = file.name;
    fileName.style.display = 'block';

    var reader = new FileReader();
    reader.onload = function(e) {
      var previewImage = document.getElementById('feyre-tryon-preview');
      var previewWrap = document.getElementById('feyre-tryon-preview-wrap');
      var loadingPreview = document.getElementById('feyre-loading-preview');

      if (previewImage && previewWrap) {
        previewImage.src = e.target.result;
        previewWrap.style.display = 'block';
      }

      if (loadingPreview) {
        loadingPreview.src = e.target.result;
      }
    };
    reader.readAsDataURL(file);
  }

  function feyreStartFakeProgress() {
    var fill = document.getElementById('feyre-progress-fill');
    var text = document.getElementById('feyre-progress-text');
    var status = document.getElementById('feyre-loading-status');

    var steps = [
      { progress: 12, label: '12% Complete', status: 'Analyzing your photo...' },
      { progress: 28, label: '28% Complete', status: 'Detecting body shape...' },
      { progress: 46, label: '46% Complete', status: 'Matching garment details...' },
      { progress: 68, label: '68% Complete', status: 'Adapting lighting and folds...' },
      { progress: 84, label: '84% Complete', status: 'Rendering final preview...' }
    ];

    var index = 0;
    fill.style.width = steps[0].progress + '%';
    text.textContent = steps[0].label;
    status.textContent = steps[0].status;

    feyreStopFakeProgress();
    feyreProgressInterval = setInterval(function() {
      index++;
      if (index >= steps.length) {
        clearInterval(feyreProgressInterval);
        return;
      }
      fill.style.width = steps[index].progress + '%';
      text.textContent = steps[index].label;
      status.textContent = steps[index].status;
    }, 1800);
  }

  function feyreStopFakeProgress() {
    if (feyreProgressInterval) {
      clearInterval(feyreProgressInterval);
      feyreProgressInterval = null;
    }
  }

  async function feyreGenerateTryOn() {
    var uploadInput = document.getElementById('feyre-tryon-upload');
    var resultImage = document.getElementById('feyre-result-image');
    var generateBtn = document.getElementById('feyre-generate-btn');

    if (!uploadInput || !uploadInput.files || !uploadInput.files[0]) {
      alert('Please choose your photo first.');
      return;
    }

    feyreHideError();
    feyreShowStep('loading');
    feyreStartFakeProgress();
    generateBtn.disabled = true;

    var userFile = uploadInput.files[0];
    var productImage = {{ product.featured_image | image_url: width: 800 | json }};

    var formData = new FormData();
    formData.append('userImage', userFile);
    formData.append('productImage', productImage);

    try {
      var response = await fetch('/apps/tryon', {
        method: 'POST',
        body: formData
      });

      var text = await response.text();

      var data;
      try {
        data = JSON.parse(text);
      } catch (e) {
        throw new Error(text);
      }

      if (!response.ok || !data.success) {
        throw new Error(data.error || 'Generation failed');
      }

      feyreStopFakeProgress();
      document.getElementById('feyre-progress-fill').style.width = '100%';
      document.getElementById('feyre-progress-text').textContent = '100% Complete';
      document.getElementById('feyre-loading-status').textContent = 'Preview ready';

      resultImage.src = data.resultImage;
      setTimeout(function() {
        feyreShowStep('result');
      }, 700);
    } catch (error) {
      feyreStopFakeProgress();
      feyreShowStep('upload');
      feyreShowError(error.message || 'Unknown error');
    } finally {
      generateBtn.disabled = false;
    }
  }
</script>

{% schema %}
{
  "name": "Try On Button",
  "target": "section",
  "settings": []
}
{% endschema %}