<div class="feyre-tryon-wrap">
  <button
    type="button"
    class="feyre-tryon-trigger"
    onclick="feyreOpenTryOnDrawer()">
    Try It On
  </button>
</div>

<div
  id="feyre-tryon-overlay"
  class="feyre-tryon-overlay"
  style="display:none;"
  onclick="feyreOverlayClose(event)">
  <div id="feyre-tryon-drawer" class="feyre-tryon-drawer">
    <button
      type="button"
      class="feyre-close-btn"
      onclick="feyreCloseTryOnDrawer()">
      ×
    </button>

    <div class="feyre-drawer-head">
      <h2>Try It On</h2>
      <div class="feyre-tryon-counter">
        <span class="feyre-counter-icon">◷</span>
        <span id="feyre-counter-text">0 Try-Ons</span>
      </div>
    </div>

    <!-- STEP 1 -->
    <div id="feyre-step-1" class="feyre-step">
      <div class="feyre-step-progress">
        <div class="feyre-step-circle active">1</div>
        <div class="feyre-step-line"></div>
        <div class="feyre-step-circle">2</div>
      </div>

      <div class="feyre-step-title">Want to see it on you?</div>
      <div class="feyre-step-subtitle">
        Upload a full-body photo to visualize the fit on yourself.
      </div>

      <div class="feyre-preview-card">
        {% if product.featured_image %}
          <img
            class="feyre-preview-image"
            src="{{ product.featured_image | image_url: width: 700 }}"
            alt="{{ product.title | escape }}"
            width="220"
            height="300">
        {% endif %}
      </div>

      <input
        type="file"
        id="feyre-tryon-upload"
        accept="image/*"
        capture="environment"
        style="display:none;"
        onchange="feyreHandlePhotoSelect(event)">

      <button
        type="button"
        class="feyre-main-btn"
        onclick="document.getElementById('feyre-tryon-upload').click()">
        + Choose Your Photo
      </button>

      <button
        type="button"
        class="feyre-alt-btn"
        onclick="document.getElementById('feyre-tryon-upload').click()">
        📷 Open Camera
      </button>

      <div class="feyre-footer-note">
        By using this service, you agree to our
        <a href="#" onclick="return false;">Terms & Privacy Policy</a>.<br>
        Photos are used solely for try-on. AI results may vary.
      </div>
    </div>

    <!-- STEP 2 -->
    <div id="feyre-step-2" class="feyre-step" style="display:none;">
      <div class="feyre-step-title review-title">Review Your Photo</div>

      <div class="feyre-preview-card review-card">
        <img
          id="feyre-review-image"
          class="feyre-review-image"
          src=""
          alt="Review photo"
          width="235"
          height="350">

        <button
          type="button"
          class="feyre-change-btn"
          onclick="document.getElementById('feyre-tryon-upload').click()">
          📷 Change Photo
        </button>
      </div>

      <button
        type="button"
        id="feyre-generate-btn"
        class="feyre-main-btn"
        onclick="feyreGenerateTryOn()">
        Generate My Look
      </button>

      <div class="feyre-footer-note compact">
        By generating a look, you agree to our
        <a href="#" onclick="return false;">Terms & Privacy Policy</a>.
      </div>

      <div class="feyre-powered">Powered by <span>FEYRE TryOn</span></div>
    </div>

    <!-- STEP 3 -->
    <div id="feyre-step-3" class="feyre-step" style="display:none;">
      <div class="feyre-step-title generating-title">Generating your fit</div>

      <div class="feyre-loading-card">
        <div class="feyre-loading-frame">
          <div class="feyre-scan-line"></div>
          <img
            id="feyre-loading-image"
            class="feyre-loading-image"
            src=""
            alt="Loading preview">
        </div>
      </div>

      <div class="feyre-progress-wrap">
        <div class="feyre-progress-bar">
          <div id="feyre-progress-fill" class="feyre-progress-fill"></div>
        </div>
        <div id="feyre-progress-label" class="feyre-progress-label">12% Complete</div>
        <div id="feyre-progress-status" class="feyre-progress-status">Analyzing Your Photo....</div>
      </div>

      <div id="feyre-loading-note" class="feyre-loading-note">
        Our AI adjusts for fabric stretch and drape on your body.
      </div>

      <div class="feyre-powered loading-powered">Powered by <span>FEYRE TryOn</span></div>
    </div>

    <!-- STEP 4 -->
    <div id="feyre-step-4" class="feyre-step" style="display:none;">
      <div class="feyre-result-head">
        <button type="button" class="feyre-back-btn" onclick="feyreBackToReview()">‹</button>
        <div class="feyre-result-title">Here Is Your Fit</div>
        <div class="feyre-tryon-counter">
          <span class="feyre-counter-icon">◷</span>
          <span id="feyre-counter-text-final">1 Try-On</span>
        </div>
      </div>

      <div class="feyre-result-card">
        <img
          id="feyre-result-image"
          class="feyre-result-image"
          src=""
          alt="Try-on result"
          width="230"
          height="360">
      </div>

      <button type="button" class="feyre-main-btn result-cart-btn">
        👜 Add To Cart — {{ product.price | money }}
      </button>

      <div class="feyre-result-actions">
        <button type="button" class="feyre-action-btn">⇪ Share</button>
        <button type="button" class="feyre-action-btn" onclick="feyreDownloadResult()">⇩ Save</button>
        <button type="button" class="feyre-action-btn" onclick="feyreCloseTryOnDrawer()">↗ View Product</button>
      </div>
    </div>

    <div id="feyre-error-box" class="feyre-error-box" style="display:none;">
      <div class="feyre-error-title">Something went wrong</div>
      <pre id="feyre-error-text"></pre>
    </div>
  </div>
</div>

<style>
  .feyre-tryon-trigger {
    padding: 12px 22px;
    border: 0;
    border-radius: 10px;
    background: #111;
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
  }

  .feyre-tryon-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .42);
    z-index: 999999;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 22px;
    box-sizing: border-box;
  }

  .feyre-tryon-drawer {
    width: 100%;
    max-width: 430px;
    height: 760px;
    background: #fff;
    border-radius: 22px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, .18);
    position: relative;
    padding: 20px 22px 22px;
    box-sizing: border-box;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .feyre-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    min-height: 0;
  }

  .feyre-close-btn,
  .feyre-main-btn,
  .feyre-alt-btn,
  .feyre-change-btn,
  .feyre-action-btn,
  .feyre-back-btn {
    position: relative;
    z-index: 20;
  }

  .feyre-close-btn {
    position: absolute;
    top: 14px;
    right: 16px;
    border: 0;
    background: transparent;
    color: #8f939a;
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
  }

  .feyre-drawer-head,
  .feyre-result-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 18px;
    flex: 0 0 auto;
  }

  .feyre-drawer-head h2,
  .feyre-result-title {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
    color: #1f2937;
  }

  .feyre-tryon-counter {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #eaf7ec;
    color: #2f7a3e;
    border-radius: 999px;
    padding: 8px 13px;
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
  }

  .feyre-step-progress {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 4px 0 20px;
    flex: 0 0 auto;
  }

  .feyre-step-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid #d7dbe2;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #a0a7b3;
    background: #fff;
    font-size: 20px;
    font-weight: 700;
  }

  .feyre-step-circle.active {
    background: #000;
    color: #fff;
    border-color: #000;
  }

  .feyre-step-line {
    width: 60px;
    height: 3px;
    background: #e5e7eb;
    border-radius: 999px;
    margin: 0 10px;
  }

  .feyre-step-title {
    text-align: center;
    font-size: 20px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 8px;
    line-height: 1.2;
    flex: 0 0 auto;
  }

  .feyre-step-subtitle {
    text-align: center;
    font-size: 13px;
    color: #97a0ac;
    line-height: 1.45;
    margin-bottom: 18px;
    flex: 0 0 auto;
  }

  .feyre-preview-card,
  .feyre-review-card {
    background: #f4f4f6;
    border-radius: 18px;
    padding: 14px;
    text-align: center;
    margin-bottom: 14px;
    flex: 0 0 auto;
  }

  .feyre-product-preview-img,
  .feyre-review-image {
    display: block;
    width: 100%;
    max-width: 220px;
    max-height: 320px;
    object-fit: contain;
    margin: 0 auto;
    border-radius: 10px;
  }

  .feyre-main-btn {
    width: 100%;
    border: 0;
    border-radius: 15px;
    background: #000;
    color: #fff;
    padding: 16px 16px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    margin-bottom: 12px;
    flex: 0 0 auto;
  }

  .feyre-main-btn:disabled {
    opacity: .65;
    cursor: not-allowed;
  }

  .feyre-alt-btn {
    width: 100%;
    border: 1px solid #d7dce3;
    border-radius: 15px;
    background: #fff;
    color: #5b6470;
    padding: 16px 16px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    margin-bottom: 14px;
    flex: 0 0 auto;
  }

  .feyre-change-btn {
    margin-top: 12px;
    border: 0;
    background: #fff;
    color: #4b5563;
    border-radius: 999px;
    padding: 10px 18px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 2px 10px rgba(0, 0, 0, .08);
  }

  .feyre-footer-note {
    text-align: center;
    color: #9ca3af;
    font-size: 11px;
    line-height: 1.45;
    margin-top: 4px;
    flex: 0 0 auto;
  }

  .feyre-footer-note a {
    color: #6d5dd3;
    text-decoration: underline;
  }

  .feyre-powered {
    text-align: center;
    color: #c2c6ce;
    font-size: 12px;
    margin-top: 12px;
    flex: 0 0 auto;
  }

  .feyre-powered span {
    color: #6d5dd3;
    font-weight: 700;
  }

  .feyre-loading-card {
    display: flex;
    justify-content: center;
    margin-bottom: 16px;
    flex: 0 0 auto;
  }

  .feyre-loading-frame {
    position: relative;
    width: 215px;
    height: 300px;
    border-radius: 22px;
    overflow: hidden;
    background: #111;
  }

  .feyre-loading-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .feyre-scan-line {
    position: absolute;
    left: 12px;
    right: 12px;
    height: 4px;
    top: 18px;
    z-index: 5;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,1), transparent);
    box-shadow: 0 0 18px rgba(255,255,255,.95);
    animation: feyreScanMove 1.8s linear infinite;
    will-change: transform;
  }

  @keyframes feyreScanMove {
    0% { transform: translateY(0); opacity: .95; }
    50% { transform: translateY(220px); opacity: 1; }
    100% { transform: translateY(0); opacity: .95; }
  }

  .feyre-progress-wrap {
    max-width: 310px;
    margin: 0 auto 14px;
    text-align: center;
    flex: 0 0 auto;
  }

  .feyre-progress-bar {
    height: 9px;
    background: #dfe3e8;
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .feyre-progress-fill {
    width: 12%;
    height: 100%;
    background: #111;
    border-radius: 999px;
    transition: width .5s ease;
  }

  .feyre-progress-label {
    color: #a3a9b4;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 5px;
  }

  .feyre-progress-status {
    color: #374151;
    font-size: 14px;
    font-weight: 700;
  }

  .feyre-loading-note {
    max-width: 310px;
    margin: 16px auto 0;
    border: 1px solid #e5e8ee;
    background: #fbfbfc;
    color: #7b8494;
    border-radius: 15px;
    padding: 13px 15px;
    text-align: center;
    font-size: 12px;
    line-height: 1.45;
    flex: 0 0 auto;
  }

  .loading-powered {
    margin-top: 18px;
  }

  .feyre-back-btn {
    border: 0;
    background: transparent;
    color: #4b5563;
    font-size: 32px;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }

  .feyre-result-card {
    background: #f4f4f6;
    border-radius: 18px;
    padding: 14px;
    text-align: center;
    margin-bottom: 14px;
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feyre-result-image {
    display: block;
    width: 100%;
    max-width: 230px;
    max-height: 360px;
    object-fit: contain;
    margin: 0 auto;
    border-radius: 10px;
  }

  .result-cart-btn {
    margin-top: 0;
    flex: 0 0 auto;
  }

  .feyre-result-actions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 10px;
    flex: 0 0 auto;
  }

  .feyre-action-btn {
    border: 1px solid #d7dce3;
    background: #fff;
    color: #6b7280;
    border-radius: 14px;
    padding: 13px 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
  }

  .feyre-error-box {
    margin-top: 14px;
    background: #fff1f2;
    border: 1px solid #fecdd3;
    border-radius: 14px;
    padding: 14px;
    flex: 0 0 auto;
  }

  .feyre-error-title {
    color: #9f1239;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .feyre-error-box pre {
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 12px;
    color: #881337;
  }

  @media (max-width: 640px) {
    .feyre-tryon-overlay {
      padding: 10px;
    }

    .feyre-tryon-drawer {
      max-width: 100%;
      height: calc(100vh - 20px);
      border-radius: 18px;
      padding: 18px 16px 18px;
    }

    .feyre-result-actions {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  let feyreProgressInterval = null;
  let feyreTryOnCount = 0;
  let feyreSelectedFile = null;

  function feyreOpenTryOnDrawer() {
    document.getElementById('feyre-tryon-overlay').style.display = 'flex';
    feyreShowStep(1);
    feyreHideError();
  }

  function feyreCloseTryOnDrawer() {
    document.getElementById('feyre-tryon-overlay').style.display = 'none';
    feyreStopProgress();
  }

  function feyreOverlayClose(event) {
    if (event.target.id === 'feyre-tryon-overlay') {
      feyreCloseTryOnDrawer();
    }
  }

  function feyreShowStep(step) {
    document.getElementById('feyre-step-1').style.display = step === 1 ? 'flex' : 'none';
    document.getElementById('feyre-step-2').style.display = step === 2 ? 'flex' : 'none';
    document.getElementById('feyre-step-3').style.display = step === 3 ? 'flex' : 'none';
    document.getElementById('feyre-step-4').style.display = step === 4 ? 'flex' : 'none';
  }

  function feyreHideError() {
    document.getElementById('feyre-error-box').style.display = 'none';
    document.getElementById('feyre-error-text').textContent = '';
  }

  function feyreShowError(message) {
    document.getElementById('feyre-error-box').style.display = 'block';
    document.getElementById('feyre-error-text').textContent = message || 'Unknown error';
  }

  function feyreUpdateCounter() {
    let text = feyreTryOnCount + ' Try-On';
    if (feyreTryOnCount !== 1) text += 's';
    document.getElementById('feyre-counter-text').textContent = text;
    const finalCounter = document.getElementById('feyre-counter-text-final');
    if (finalCounter) finalCounter.textContent = text;
  }

  function feyreHandlePhotoSelect(event) {
    const file = event.target.files && event.target.files[0];
    if (!file) return;

    feyreSelectedFile = file;
    feyreHideError();

    const reader = new FileReader();
    reader.onload = function(e) {
      document.getElementById('feyre-review-image').src = e.target.result;
      document.getElementById('feyre-loading-image').src = e.target.result;
      feyreShowStep(2);
    };
    reader.readAsDataURL(file);
  }

  function feyreStartProgress() {
    const fill = document.getElementById('feyre-progress-fill');
    const label = document.getElementById('feyre-progress-label');
    const status = document.getElementById('feyre-progress-status');
    const note = document.getElementById('feyre-loading-note');

    const steps = [
      { progress: 12, label: '12% Complete', status: 'Analyzing Your Photo....', note: 'Our AI adjusts for fabric stretch and drape on your body.' },
      { progress: 24, label: '24% Complete', status: 'Mapping body shape....', note: 'Understanding your proportions and posture.' },
      { progress: 39, label: '39% Complete', status: 'Matching garment details....', note: 'Aligning outfit shape and silhouette.' },
      { progress: 55, label: '55% Complete', status: 'Refining fit and drape....', note: 'Improving folds, edges and garment fall.' },
      { progress: 71, label: '71% Complete', status: 'Balancing lighting and texture....', note: 'Improving realism and detail.' },
      { progress: 86, label: '86% Complete', status: 'Rendering final preview....', note: 'Almost ready.' }
    ];

    let index = 0;

    fill.style.width = steps[0].progress + '%';
    label.textContent = steps[0].label;
    status.textContent = steps[0].status;
    note.textContent = steps[0].note;

    feyreStopProgress();

    feyreProgressInterval = setInterval(function() {
      index++;
      if (index >= steps.length) return;

      fill.style.width = steps[index].progress + '%';
      label.textContent = steps[index].label;
      status.textContent = steps[index].status;
      note.textContent = steps[index].note;
    }, 1100);
  }

  function feyreStopProgress() {
    if (feyreProgressInterval) {
      clearInterval(feyreProgressInterval);
      feyreProgressInterval = null;
    }
  }

  function feyreBackToReview() {
    feyreShowStep(2);
    feyreHideError();
  }

  function feyreDownloadResult() {
    const img = document.getElementById('feyre-result-image');
    if (!img || !img.src) return;

    const a = document.createElement('a');
    a.href = img.src;
    a.download = 'feyre-tryon-result.png';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  }

  async function feyreGenerateTryOn() {
    if (!feyreSelectedFile) {
      feyreShowError('Please choose a photo first.');
      return;
    }

    feyreHideError();
    feyreShowStep(3);
    feyreStartProgress();

    const formData = new FormData();
    const productImage = {{ product.featured_image | image_url: width: 800 | json }};

    formData.append('userImage', feyreSelectedFile);
    formData.append('productImage', productImage);

    try {
      const response = await fetch('/apps/tryon', {
        method: 'POST',
        body: formData
      });

      const text = await response.text();
      let data;

      try {
        data = JSON.parse(text);
      } catch (e) {
        throw new Error(text);
      }

      if (!response.ok || !data.success) {
        throw new Error(data.error || 'Generation failed');
      }

      feyreStopProgress();
      document.getElementById('feyre-progress-fill').style.width = '100%';
      document.getElementById('feyre-progress-label').textContent = '100% Complete';
      document.getElementById('feyre-progress-status').textContent = 'Preview ready';

      document.getElementById('feyre-result-image').src = data.resultImage;
      feyreTryOnCount += 1;
      feyreUpdateCounter();

      setTimeout(function() {
        feyreShowStep(4);
      }, 500);
    } catch (error) {
      feyreStopProgress();
      feyreShowStep(2);
      feyreShowError(error.message || 'Unknown error');
    }
  }
</script>

{% schema %}
{
  "name": "Try On Button",
  "target": "section",
  "settings": []
}
{% endschema %}